<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SessiaAval.LoginWindow"
        Title="Вход в систему"
        Width="450" Height="500"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Background="#F8F8F8">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="30" Padding="40"
                BoxShadow="0 4 20 0 #15000000">
            <StackPanel Spacing="20">
                <Border Width="100" Height="100" CornerRadius="50" ClipToBounds="True"
                        HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Image Source="avares://SessiaAval/Assets/Logo.png" Stretch="UniformToFill"/>
                </Border>

                <TextBlock Text="МАТЬЕ" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2C2C2C"/>
                
                <TextBlock Text="Вход в систему" FontSize="14" 
                           HorizontalAlignment="Center" Foreground="#666666" Margin="0,0,0,10"/>

                <StackPanel Spacing="8">
                    <TextBlock Text="Email" Foreground="#2C2C2C" FontWeight="SemiBold"/>
                    <TextBox x:Name="emailTextBox" Watermark="example@mail.ru"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Пароль" Foreground="#2C2C2C" FontWeight="SemiBold"/>
                    <TextBox x:Name="passwordTextBox" PasswordChar="●" Watermark="Введите пароль"/>
                </StackPanel>

                <TextBlock x:Name="errorTextBlock" Text="" Foreground="#D32F2F" 
                           FontSize="12" TextWrapping="Wrap" IsVisible="False"/>

                <Button Content="Войти" Classes="primary" Click="onLoginClick"
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                    <TextBlock Text="Нет аккаунта?" Foreground="#666666"/>
                    <Button Content="Зарегистрироваться" 
                            Background="Transparent" 
                            Foreground="#2C2C2C" 
                            BorderThickness="0"
                            Padding="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="onRegisterClick"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
